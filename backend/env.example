# Copiar a .env y completar valores reales

MONGO_URI=
PORT=4000
SESSION_SECRET=

# Origen del frontend (sesión + chatbot con cookies). Una URL o varias separadas por coma.
# Ejemplo Live Server: http://127.0.0.1:5500
# FRONTEND_ORIGIN=http://127.0.0.1:5500
# Más orígenes opcionales (además de los que ya trae el servidor por defecto):
# CORS_ORIGINS=http://localhost:9000,https://mi-dominio.com

# Administrador (en producción: definí siempre ADMIN_EMAIL + ADMIN_PASSWORD)
# Tras el primer arranque, el usuario con este email tendrá rol "admin".
# Si no existe, se crea con la contraseña indicada (mínimo 10 caracteres).
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=

# Solo si necesitás forzar que la contraseña del admin coincida de nuevo con .env:
# ADMIN_SYNC_PASSWORD=true

# Desarrollo (NODE_ENV distinto de production): si ADMIN_EMAIL está vacío, el servidor
# crea/promueve admin@mmdr.dev con contraseña MmdrDev2026! (ver consola al arrancar).
# Opcional: personalizar sin tocar código:
# DEV_ADMIN_EMAIL=mi@local.dev
# DEV_ADMIN_PASSWORD=MiClaveLarga123
